{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gerador de Relatorio de Notas",
  "version": "0.1.0",
  "identifier": "com.pratica.gerador-relatorio-notas",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gerador de Relatorio de Notas",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/icon.ico",
      "icons/android-chrome-192x192.png",
      "icons/android-chrome-512x512.png",
      "icons/apple-touch-icon.png",
      "icons/favicon-32x32.png",
      "icons/favicon-16x16.png"
    ]
  }
}
